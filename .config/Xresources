rofi.terminal: gnome-terminal

!yeahconsole

yeahconsole*toggleKey: None+F8
yeahconsole*consoleHeight: 20
yeahconsole*aniDelay: 0
yeahnsole*stepSize: 10
yeahconsole*faceName: NotoSans:style=Regular
yeahconsole*faceSize: 9

! Specifies the terminal type name to be set in the TERM environment variable
URxvt.termName:         rxvt-256color

! True: start as a login shell by prepending a - to argv[0] of the shell; option -ls.  False: start as >
Urxvt*loginShell: false


!Terminal Colors
!*foreground:#a0a0a0
!*background:#1b1d1e


! Colorscheme

! special
*.foreground: #93a1a1
*.background: #141c21
*.cursorColor: #afbfbf

! black
