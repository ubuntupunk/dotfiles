    foreground = "#52bbb7"
    timeout = 13

[urgency_critical]
    background = "#191919"
    foreground = "#ca4862"
    timeout = 15

[irc]
    appname = "weechat"
    format  = "%s: %b"
    urgency = low
    background = "#83c83d"
    foreground = "#000000"

