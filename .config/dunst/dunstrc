always_run_script = true
title = Dunst
class = Dunst
bounce_freq = 0
browser = /usr/bin/vivaldi -new-tab
dmenu = /usr/bin/dmenu -p dunst:
follow = none
font = Awesome 12
format = "<b>%s</b>\n%b"
 # geometry [{width}]x{height}][+/-{x}+/-{y}]
geometry = "0-8+65"
