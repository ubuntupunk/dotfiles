#apply wallpaper
exec_always feh --bg-scale ~/Pictures/Wallpapers/default.jpeg

#powermenu
bindsym Control+Mod1+Delete exec $HOME/.config/i3/scripts/shutdown_menu

#save window layouts
bindsym $mod+F3 exec i3-resurrect save -d $HOME/.config/i3/resurrect/
bindsym $mod+F4 exec i3-resurrect restore -d $HOME/.config/i3/resurrect/

#---------------------------
#SYSTEM STATUS AND STUFF
#---------------------------
#lockscreen
bindsym $mod+shift+x exec betterlockscreen --lock 
#Set image for lockscreen
#where /lock contains wallpapers for lockscreen
exec --no-startup-id betterlockscreen -u ~/.config/i3/ilock/
#Suspend the system
bindsym $mod+Shift+s exec betterlockscreen --lock & systemctl suspend

## Use pactl to adjust volume in PulseAudio.
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ 1 +5% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

# Media player controls
bindsym XF86AudioPlay exec playerctl play
bindsym XF86AudioPause exec playerctl pause
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous

bindsym XF86PowerOff exec --no-startup-id prompt "Shutdown computer?" "$shutdown"

bindsym Print exec screenshot

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# start a terminal
bindsym $mod+Return exec i3-sensible-terminal

# or alt bindsym $mod+Return exec urxvt

# kill focused window
bindsym $mod+Shift+q kill

# start dmenu (a program launcher)
bindsym $mod+F2 exec dmenu_run -p chooser: -l 5 -nf "#6FCB9F" -sf "#ffe28a" -fn Hack

#or start rofi as dmenu replacement
bindsym Mod1+d exec rofi -show run -font "System San Francisco Display 14"

